{
  "name": "@barkajs/barka",
  "version": "0.1.0",
  "description": "AI-native progressive Content-as-Code CMS. Built for AI coding agents. Files-first, optional database.",
  "type": "module",
  "bin": {
    "barka": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/built-in-theme/",
    "starters/",
    "CLAUDE.md",
    "INVARIANTS.json",
    "LICENSE"
  ],
  "scripts": {
    "build:src": "tsc",
    "dev": "tsx src/cli/index.ts dev",
    "build": "tsx src/cli/index.ts build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "npm run typecheck && npm test && tsc"
  },
  "keywords": [
    "cms",
    "content",
    "markdown",
    "hono",
    "htmx",
    "sqlite",
    "sections",
    "seo"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/barkajs/barka"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^4.0.0",
    "commander": "^13.1.0",
    "drizzle-orm": "^0.45.1",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.7.0",
    "js-yaml": "^4.1.0",
    "marked": "^15.0.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
